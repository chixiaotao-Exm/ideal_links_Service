# Optional proxy. Keep real values in .env or server environment only.
# Examples without credentials:
# OPENAI_PAY_DEFAULT_PROXY=http://proxy.example.com:8080
# OPENAI_PAY_PROVIDER_PROXY=http://provider-proxy.example.com:8080
# OPENAI_PAY_GOPAY_PROVIDER_PROXY=http://gopay-proxy.example.com:8080
# OPENAI_PAY_711_REFRESH_URLS={"JP":"https://proxy-provider.example/refresh?region=JP"}
OPENAI_PAY_DEFAULT_PROXY=
OPENAI_PAY_PROVIDER_PROXY=
OPENAI_PAY_GOPAY_PROVIDER_PROXY=
OPENAI_PAY_711_REFRESH_URLS={}

# Optional payment/front-end integration placeholders.
OPENAI_PAY_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_YOUR_PUBLISHABLE_KEY
ICLOUD_MAIL_LOOKUP_URL=
ICLOUD_MAIL_API_KEY=
ICLOUD_MAIL_PURCHASE_URL=https://example.com/shop/icloud-mail

# Tuning
OPENAI_PAY_PAYPAL_PROVIDER_ATTEMPTS=10
OPENAI_PAY_PROXY_REGION_CHECK_ATTEMPTS=2
OPENAI_PAY_CHECKOUT_ATTEMPTS=5
OPENAI_PAY_STRIPE_INIT_ATTEMPTS=3
OPENAI_PAY_QUEUE_TASK_INTERVAL_SECONDS=30
OPENAI_PAY_VIRTUAL_QUEUE_MIN=2
OPENAI_PAY_VIRTUAL_QUEUE_MAX=17
